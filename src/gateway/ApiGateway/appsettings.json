{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Secret": "YourSuperSecretKeyForJwtTokenGenerationMinimum32Characters",
    "Issuer": "BitirmeProject.IdentityService",
    "Audience": "BitirmeProject.Clients"
  },
  "ReverseProxy": {
    "Routes": {
      "identity": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/api/v1/identity/{**catch-all}"
        }
      },
      "projects": {
        "ClusterId": "projects",
        "Match": {
          "Path": "/api/v1/projects/{**catch-all}"
        }
      },
      "issues": {
        "ClusterId": "issues",
        "Match": {
          "Path": "/api/v1/issues/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "d1": {
            "Address": "http://identity-api:8080/"
          }
        }
      },
      "projects": {
        "Destinations": {
          "d1": {
            "Address": "http://project-api:8080/"
          }
        }
      },
      "issues": {
        "Destinations": {
          "d1": {
            "Address": "http://issue-api:8080/"
          }
        }
      }
    }
  }
}