# Copy this file to .env and fill in the values before running docker-compose.
# Never commit the real .env to version control.

# ---- JWT ----
JWT_SECRET=change-me-minimum-32-chars-long-secret-key
JWT_ISSUER=BitirmeProject.IdentityService
JWT_AUDIENCE=BitirmeProject.Clients

# ---- RabbitMQ ----
RABBITMQ_USER=admin
RABBITMQ_PASS=change-me-rabbitmq-password

# ---- Redis ----
REDIS_PASS=change-me-redis-password

# ---- Database passwords ----
IDENTITY_DB_PASS=change-me-identity-db-password
PROJECT_DB_PASS=change-me-project-db-password
ISSUE_DB_PASS=change-me-issue-db-password
SPRINT_DB_PASS=change-me-sprint-db-password
NOTIFICATION_DB_PASS=change-me-notification-db-password
STORAGE_DB_PASS=change-me-storage-db-password
AI_DB_PASS=change-me-ai-db-password

# ---- Admin seeder ----
SEED_ADMIN=true
ADMIN_PASSWORD=change-me-strong-admin-password
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin

# ---- Cors ----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Ollama ----
# On Linux Docker hosts, set to http://host.docker.internal:11434 (extra_hosts maps this automatically)
# On Windows/Mac Docker Desktop, the default works without changes
OLLAMA_BASE_URL=http://host.docker.internal:11434
