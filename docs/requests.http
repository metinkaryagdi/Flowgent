# Auth flow: Login sets HttpOnly cookies (access_token + refresh_token).
# All subsequent requests use cookies automatically — no manual token copy needed.
# Use a REST client that supports cookies (e.g. VS Code REST Client with cookie jar, Insomnia, Postman).

### Register
POST http://localhost:5000/api/v1/identity/register
Content-Type: application/json

{
  "userName": "demo.user",
  "email": "demo.user@example.com",
  "password": "Demo123!"
}

### Login — sets access_token + refresh_token cookies
POST http://localhost:5000/api/v1/identity/login
Content-Type: application/json

{
  "userNameOrEmail": "demo.user",
  "password": "Demo123!"
}

### Refresh token — uses refresh_token cookie, returns new access_token cookie
POST http://localhost:5000/api/v1/identity/refresh

### Logout — clears both cookies
POST http://localhost:5000/api/v1/identity/logout

### Create Project
POST http://localhost:5000/api/v1/projects
Content-Type: application/json

{
  "name": "Demo Project",
  "key": "DEMO"
}

### Get Project Members
GET http://localhost:5000/api/v1/projects/{{projectId}}/members

### Create Issue
POST http://localhost:5000/api/v1/issues
Content-Type: application/json

{
  "projectId": "{{projectId}}",
  "title": "First issue",
  "description": "Issue description",
  "priority": 1
}

### Assign Issue
POST http://localhost:5000/api/v1/issues/{{issueId}}/assign
Content-Type: application/json

{
  "issueId": "{{issueId}}",
  "assigneeUserId": "{{userId}}"
}

### Change Issue Status
POST http://localhost:5000/api/v1/issues/{{issueId}}/status
Content-Type: application/json

{
  "issueId": "{{issueId}}",
  "newStatus": 1
}

### Get Issues By Sprint
GET http://localhost:5000/api/v1/issues/sprint/{{sprintId}}

### Attach File To Issue (metadata only)
POST http://localhost:5000/api/v1/issues/{{issueId}}/attachments
Content-Type: application/json

{
  "issueId": "{{issueId}}",
  "fileId": "{{fileId}}",
  "fileName": "spec.pdf",
  "contentType": "application/pdf",
  "sizeBytes": 123456
}

### Get Issue Attachments
GET http://localhost:5000/api/v1/issues/{{issueId}}/attachments

### Create Sprint
POST http://localhost:5000/api/v1/sprints
Content-Type: application/json

{
  "projectId": "{{projectId}}",
  "name": "Sprint 1",
  "goal": "Ship MVP"
}

### Start Sprint
POST http://localhost:5000/api/v1/sprints/{{sprintId}}/start
Content-Type: application/json

{
  "sprintId": "{{sprintId}}"
}

### Add Issue To Sprint
POST http://localhost:5000/api/v1/sprints/{{sprintId}}/issues
Content-Type: application/json

{
  "sprintId": "{{sprintId}}",
  "issueId": "{{issueId}}"
}

### Remove Issue From Sprint
DELETE http://localhost:5000/api/v1/sprints/{{sprintId}}/issues/{{issueId}}

### Get Active Sprint
GET http://localhost:5000/api/v1/sprints/project/{{projectId}}/active

### Get Sprint Issues
GET http://localhost:5000/api/v1/sprints/{{sprintId}}/issues

### Get Sprint Velocity
GET http://localhost:5000/api/v1/sprints/{{sprintId}}/velocity

### Get Sprint Backlog
GET http://localhost:5000/api/v1/sprints/project/{{projectId}}/backlog

### Upload File (Storage)
POST http://localhost:5000/api/v1/storage/files
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="file"; filename="example.txt"
Content-Type: text/plain

Hello storage
--boundary--

### Get File Metadata (Storage)
GET http://localhost:5000/api/v1/storage/files/{{fileId}}

### Download File (Storage)
GET http://localhost:5000/api/v1/storage/files/{{fileId}}/content

### Delete File (Storage)
DELETE http://localhost:5000/api/v1/storage/files/{{fileId}}
